    :exhibitsSymptom :extra_marital_contacts,
        :high_fever,
        :muscle_wasting,
        :patches_in_throat ;
    :name "Isabela Cristina Morcela" .

:Patient_0015 a :Patient ;
    :exhibitsSymptom :abdominal_pain,
        :indigestion,
        :internal_itching,
        :loss_of_appetite,
        :passage_of_gases,
        :vomiting ;
