@prefix : <http://rpcw.di.uminho.pt/2026/untitled-ontology-13/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://rpcw.di.uminho.pt/2026/untitled-ontology-13/> .

<http://rpcw.di.uminho.pt/2026/untitled-ontology-13> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/nome
:nome rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/escritoPor
:escritoPor rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf owl:topObjectProperty ;
            rdfs:domain :Livro ;
            rdfs:range :Autor .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/existeEm
:existeEm rdf:type owl:ObjectProperty ;
          rdfs:domain :Livro ;
          rdfs:range :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/ocorreEm
:ocorreEm rdf:type owl:ObjectProperty ;
          rdfs:domain :Evento ;
          rdfs:range :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/pertenceA
:pertenceA rdf:type owl:ObjectProperty ;
           rdfs:domain :Livro ;
           rdfs:range :Biblioteca .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/refere
:refere rdf:type owl:ObjectProperty ;
        rdfs:domain :Livro ;
        rdfs:range :Evento .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/requisita
:requisita rdf:type owl:ObjectProperty ;
           rdfs:domain :Leitor ;
           rdfs:range :Livro .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/temLivro
:temLivro rdf:type owl:ObjectProperty ;
          rdfs:domain :Evento ;
          rdfs:range :Livro .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/trabalhaEm
:trabalhaEm rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Agente
:Agente rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Autor
:Autor rdf:type owl:Class ;
       rdfs:subClassOf :Pessoa .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Biblioteca
:Biblioteca rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Bibliotecário
:Bibliotecário rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Pessoa
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :trabalhaEm ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass :Biblioteca
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Empréstimo
:Empréstimo rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/EntidadeTemporal
:EntidadeTemporal rdf:type owl:Class ;
                  rdfs:subClassOf :Agente .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Evento
:Evento rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/EventoFuturo
:EventoFuturo rdf:type owl:Class ;
              rdfs:subClassOf :Evento .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/EventoHistórico
:EventoHistórico rdf:type owl:Class ;
                 rdfs:subClassOf :Evento .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Leitor
:Leitor rdf:type owl:Class ;
        rdfs:subClassOf :Pessoa .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/LinhaAlternativa
:LinhaAlternativa rdf:type owl:Class ;
                  rdfs:subClassOf :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/LinhaOriginal
:LinhaOriginal rdf:type owl:Class ;
               rdfs:subClassOf :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/LinhaParadoxal
:LinhaParadoxal rdf:type owl:Class ;
                rdfs:subClassOf :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/LinhaTemporal
:LinhaTemporal rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Livro
:Livro rdf:type owl:Class ;
       owl:equivalentClass [ rdf:type owl:Restriction ;
                             owl:onProperty :existeEm ;
                             owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                             owl:onClass :LinhaTemporal
                           ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/LivroFiccional
:LivroFiccional rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Livro
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :refere ;
                                                             owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                 owl:complementOf :EventoHistórico
                                                                               ]
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                owl:disjointWith :LivroHistórico .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/LivroHistórico
:LivroHistórico rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Livro
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :refere ;
                                                             owl:allValuesFrom :EventoHistórico
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/LivroParadoxal
:LivroParadoxal rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Livro
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :existeEm ;
                                                             owl:someValuesFrom :LinhaAlternativa
                                                           ]
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :existeEm ;
                                                             owl:someValuesFrom :LinhaOriginal
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-13/Pessoa
:Pessoa rdf:type owl:Class ;
        rdfs:subClassOf :Agente .


