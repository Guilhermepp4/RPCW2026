@prefix : <http://www.semanticweb.org/guilhermepinho/ontologies/2026/2/bibliotecas/> .
@prefix default1: <http://www.semanticweb.org/guilhermepinho/ontologies/2026/2/bibliotecas> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

default1: a owl:Ontology .

:Biblioteca_Entre_Ontem_e_Amanha a :Biblioteca,
        owl:NamedIndividual .

:Cronos a :Autor,
        :Bibliotecario,
        owl:NamedIndividual .

:Emprestimo a owl:Class .

:EntidadeTemporal a owl:Class ;
    rdfs:subClassOf :Agente .

:EventoFuturo a owl:Class ;
    rdfs:subClassOf :Evento .

:Linha_T0 a :LinhaOriginal,
        owl:NamedIndividual .

:Linha_T1 a :LinhaAlternativa,
        owl:NamedIndividual .

:LivroFiccional a owl:Class ;
    owl:disjointWith :LivroHistorico ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Livro [ a owl:Restriction ;
                        owl:allValuesFrom [ a owl:Class ;
                                owl:complementOf :EventoHistorico ] ;
                        owl:onProperty :refereEvento ] ) ] .

:LivroParadoxal a owl:Class ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Livro [ a owl:Restriction ;
                        owl:onProperty :existeEm ;
                        owl:someValuesFrom :LinhaAlternativa ] [ a owl:Restriction ;
                        owl:onProperty :existeEm ;
                        owl:someValuesFrom :LinhaOriginal ] ) ] .

:escritoPor a owl:ObjectProperty ;
    rdfs:domain :Livro ;
    rdfs:range :Autor .

:ocorremEm a owl:ObjectProperty ;
    rdfs:domain :Evento ;
    rdfs:range :LinhaTemporal .

:pertenceA a owl:ObjectProperty ;
    rdfs:domain :Livro ;
    rdfs:range :Biblioteca .

:requisitam a owl:ObjectProperty ;
    rdfs:domain :Leitor ;
    rdfs:range :Livro .

